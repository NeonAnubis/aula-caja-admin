# =============================================================
# Copy this file to .env.local and fill the real values
# =============================================================

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your_publishable_key>

# Runtime connection (transaction-mode pooler, IPv4 friendly)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migration connection (session-mode pooler)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# Server-side only secrets
SERVICE_ROLE_KEY=<paste from Supabase Dashboard > Settings > API>
JWT_SECRET_KEY=<paste from Supabase Dashboard > Settings > API>

NEXT_PUBLIC_APP_URL=http://localhost:3000
