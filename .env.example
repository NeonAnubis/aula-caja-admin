# =============================================================
# Copy this file to .env.local and fill the real values
# =============================================================

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your_publishable_key>

# Runtime connection (transaction-mode pooler, IPv4 friendly)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migration connection (session-mode pooler)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# Server-side only secrets
SERVICE_ROLE_KEY=<paste from Supabase Dashboard > Settings > API>
JWT_SECRET_KEY=<paste from Supabase Dashboard > Settings > API>

# Base URL of this deployment. In production, auth email-confirmation links are
# derived from the request host automatically (see src/lib/url.ts), so this is
# only a fallback. You CAN still set it in Vercel to force a canonical domain:
#   local dev  -> http://localhost:3000
#   production -> https://aula-caja.vercel.app   (user app)
#                 https://aula-caja-admin.vercel.app   (admin app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------------------------------
# IMPORTANT for production email confirmation (Supabase Dashboard):
#   Authentication > URL Configuration
#     Site URL:       https://aula-caja.vercel.app
#     Redirect URLs:  https://aula-caja.vercel.app/**
#                     https://aula-caja-admin.vercel.app/**
#                     http://localhost:3000/**   (keep for dev)
# Without these, Supabase ignores emailRedirectTo and falls back to the
# Site URL, which defaults to http://localhost:3000.
# -------------------------------------------------------------------
